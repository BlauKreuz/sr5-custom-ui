{{!--
  Override of: systems/shadowrun5e/dist/templates/v2/list-items/skill/header.hbs
  Change: non-rtg labels changed to <span> so bundle.css's
  ".active-skills-header:hover label { color: white !important }" does not match them.
  The rtg element stays a <label class="skill-rtg-label"> for styling.
--}}
<div class="list-item list-item-header {{cssClass}}"
     {{#if headerAction}}
     data-action="{{headerAction}}"
     {{/if}}
>
    <div class="list-item-start">
        <span class="sr5cui-static-label">{{localize label}}</span>
    </div>
    {{#if @root.isPlayMode}}
    <div class="list-item-col">
        <span class="sr5cui-static-label">{{localize "SR5.Specializations"}}</span>
    </div>
    {{/if}}
    <div class="list-item-col {{#if @root.isPlayMode}} skinny-col {{/if}}">
        <label class="skill-rtg-label">
            {{#if (or @root.filters.showUntrainedSkills (not (eq category 'active')))}}
                {{localize "SR5.Rtg"}}
            {{else}}
                {{localize "SR5.RtgAboveZero"}}
            {{/if}}
        </label>
    </div>
    <div class="list-item-icons{{#if @root.isPlayMode}} skinny-icons {{/if}}">
        {{#if @root.isEditMode}}
            {{#if addAction}}
                {{> "systems/shadowrun5e/dist/templates/v2/list-items/add-icon.hbs"
                    action=addAction tooltip="SR5.Add" type='skill' data=(skillAddItemData category knowledgeType) }}
            {{/if}}
        {{/if}}
    </div>
</div>
