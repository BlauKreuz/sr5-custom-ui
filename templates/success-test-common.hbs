{{!--
  Override of: systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-common.hbs
  Changes from original:
    - Roll mode selection removed (custom roll-mode buttons in the dialog footer handle this)
    - Modify Roll section always starts collapsed (no expanded class on first render)
    - Pool and Limit use the modifiable-value entry partial (with breakdown list)
    - Threshold kept as plain input (module JS wraps it with stepper buttons)
    - Old Modifiers input removed (no longer functional in the new SR5 version)
    - Manual Hits / Glitches block retained
--}}
<div class="dialog-content-common">
    {{#if test.hasCode}}
    <hr/>
    <div class="common-test">
        {{test.code}}
        {{#if test.hitsIcon}}<img class="test-icon" src="{{test.hitsIcon.icon}}" data-tooltip="{{test.hitsIcon.tooltip}}" />{{/if}}
    </div>
    {{/if}}

    <hr/>
    <div>
        {{! --- Dice Pool (modifiable, with breakdown list) --- }}
        {{> "systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-entry.hbs"
            path="test.data.pool"
            data=test.data.pool
            label="SR5.DicePool"
            tooltip="SR5.Tooltips.Test.Pool"
        }}
        {{! --- Limit (modifiable, with breakdown list) --- }}
        {{> "systems/shadowrun5e/dist/templates/apps/dialogs/parts/success-test-entry.hbs"
            path="test.data.limit"
            data=test.data.limit
            label="SR5.Limit"
            tooltip="SR5.Tooltips.Test.Limit"
        }}
        {{! --- Threshold (plain input — module JS adds stepper buttons) --- }}
        <div class="form-group">
            <label data-tooltip="SR5.Tooltips.Test.Threshold">{{localize "SR5.Threshold"}}</label>
            <input type='number' name='test.data.threshold' size='3' maxlength='3'
                   value='{{test.threshold.value}}'
                   data-dtype="Number"/>
        </div>
    </div>

    {{#if test.allowManualHits}}
    <hr/>
    <div>
        <div class="form-group">
            <label data-tooltip="SR5.Tooltips.Test.ManualHits">{{localize "SR5.ManualHits"}}</label>
            <input type='number' name='test.data.manualHits' size='3' maxlength='3' value='{{#if test.data.manualHits.override}}{{test.data.manualHits.value}}{{/if}}' data-dtype="Number" placeholder=""/>
        </div>
        <div class="form-group">
            <label data-tooltip="SR5.Tooltips.Test.ManualGlitches">{{localize "SR5.ManualGlitches"}}</label>
            <input type='number' name='test.data.manualGlitches' size='3' maxlength='3' value='{{#if test.data.manualGlitches.override}}{{test.data.manualGlitches.value}}{{/if}}' data-dtype="Number" placeholder=""/>
        </div>
    </div>
    {{/if}}

    <hr/>
    <div class="modify-roll-section {{#if (includes expandedPaths 'modify-roll')}}expanded{{/if}}" data-section="modify-roll">
        <div class="modify-roll-header">
            <label class="modify-roll-title">{{localize "SR5.ModifyRoll"}}</label>
<!--
            <a class="toggle-modify-roll" title="{{localize 'SR5.ToggleSection'}}">
                <i class="fas fa-chevron-up"></i>
            </a>
            -->
        </div>

        <div class="modify-roll-content">
            <div class="form-group toggle-checkbox-row">
                <label data-tooltip="SR5.Tooltips.Test.BuyHits">{{localize "SR5.BuyHits"}}</label>
                <input type="checkbox" name="test.data.buyHits" {{#if test.hasBuyHits}}checked{{/if}} />
            </div>

            {{#if test.actor}}
            <div class="form-group toggle-checkbox-row">
                <label data-tooltip="SR5.Tooltips.Test.PushTheLimit">{{localize "SR5.PushTheLimit"}}
                    ({{test.actor.system.attributes.edge.uses}}/{{test.actor.system.attributes.edge.value}})</label>
                <input type="checkbox" name="test.data.pushTheLimit" {{#if test.hasPushTheLimit}}checked{{/if}}/>
            </div>
            {{/if}}

            {{#if test.canBeExtended}}
            <div class="form-group toggle-checkbox-row">
                <label data-tooltip="SR5.Tooltips.Test.Extended">{{localize "SR5.Extended"}}</label>
                <input type="checkbox" name="test.data.extended" {{#if test.extended}}checked{{/if}} />
            </div>
            {{/if}}
        </div>
    </div>
</div>
