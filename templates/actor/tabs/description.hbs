{{!-- Override of: systems/shadowrun5e/dist/templates/v2/actor/E:/Foundry/V13/data/Data/modules/sr5-custom-ui/templates/actor/tabs/description.hbs
     Edit this file to customise the actor sheet layout. It shadows the SR5 system template. --}}
<section class="tab hide-overflow{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}">
    <div class="fill-container">
        <div class="list-item list-item-header">
            <div class="list-item-start">
                <label>{{localize "SR5.Description"}}</label>
            </div>
        </div>
        <div class="scrollable">
            {{#if @root.isEditMode}}
                {{formInput systemFields.description.fields.value value=source.system.description.value rootId=@root.rootId}}
            {{else}}
                {{{biographyHTML}}}
            {{/if}}
        </div>
    </div>
</section>
