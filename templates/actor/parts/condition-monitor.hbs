{{!-- Override of: systems/shadowrun5e/dist/templates/v2/actor/E:/Foundry/V13/data/Data/modules/sr5-custom-ui/templates/actor/parts/condition-monitor.hbs
     Edit this file to customise the actor sheet layout. It shadows the SR5 system template. --}}
{{> 'systems/shadowrun5e/dist/templates/v2/common/horizontal-cells.hbs'
        tooltip=tooltip
        value=track.value
        max=track.max
        id=id
        tolerance=tolerance
        toleranceBase=track.pain_tolerance
        disabled=track.disabled
}}
{{#if track.overflow}}
    {{#ife track.value track.max}}
        {{> 'systems/shadowrun5e/dist/templates/v2/common/horizontal-cells.hbs'
                tooltip=(localize "SR5.Overflow")
                value=track.overflow.value
                max=track.overflow.max
                id="overflow"
        }}
    {{/ife}}
{{/if}}
