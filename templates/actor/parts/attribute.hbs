{{!--
  Override of: systems/shadowrun5e/dist/templates/v2/actor/parts/attribute.hbs
  Updated for SR5 system 0.34.2.
  Changes from original:
    - cssClass support added to root div
    - data-context-menu="attribute" added to root div
    - modifierTooltipPath support added to roll button
--}}
<div class="attribute{{#if cssClass}} {{cssClass}}{{/if}}" data-attribute-id="{{attributeField.name}}" data-context-menu="attribute">
    <label {{#if @root.isEditMode}}class="edit-mode"{{/if}}>
        {{#if label}}
            {{localize label}}
        {{else}}
            {{localize attribute.label}}
        {{/if}}
    </label>
    <div class="attribute-value">
        {{#if @root.isEditMode}}
            {{formInput attributeField.fields.base value=attribute.base
                        classes="short skinny center" rootId=rootId }}
        {{else}}
            <button class="icon sr5-icon" type="button"
                    data-action="rollAttribute"
                    data-attribute-modifier-tooltip="{{attributeField.name}}"
                    {{#if modifierTooltipPath}}data-modifier-tooltip-path="{{modifierTooltipPath}}"{{/if}}>
                        {{attribute.value}}
                    </button>
        {{/if}}
    </div>
</div>
